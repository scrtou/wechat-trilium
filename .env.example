# 微信公众号服务器配置里你自己填写的 Token，不是 AppSecret
WECHAT_TOKEN=change-me-random-token

# 下载图片/语音临时素材需要 AppID/AppSecret。
# AppSecret 不要提交到 Git；正式使用前建议重置已经泄露过的 AppSecret。
WECHAT_APP_ID=wx2e25b1880ef70eba
WECHAT_APP_SECRET=put-your-app-secret-here

# 初期建议公众号后台选择：明文模式
WECHAT_AES_KEY=

# TriliumNext
TRILIUM_BASE_URL=https://trilium.azhen.de
TRILIUM_ETAPI_TOKEN=put-your-etapi-token-here
TRILIUM_PARENT_NOTE_ID=PYAtaQPDBHKf

# 服务监听
HOST=0.0.0.0
PORT=8000

# 按这个时区归档到日期文件夹
ARCHIVE_TIMEZONE=Asia/Shanghai

# 只处理你自己的 OpenID；多个用英文逗号分隔。
# 你的日志中看到的 openid 是下面这个。
OWNER_OPENIDS=o_Yjr0Uhm19Xb9kG24PqIBUEP_eE
PROCESS_OWNER_ONLY=true

# 是否给自己回复“已保存”
REPLY_TO_OWNER=false
